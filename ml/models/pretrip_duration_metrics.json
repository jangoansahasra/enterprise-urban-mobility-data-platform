        "is_weekend",
        "passenger_count",
        "trip_distance",
        "pickup_borough",
        "dropoff_borough",
        "payment_type_id"
    ],
    "excluded_post_trip_features": [
        "fare_amount",
        "total_amount",
        "tip_amount"
    ]
}